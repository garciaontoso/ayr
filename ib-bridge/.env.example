# IB Gateway connection
IBKR_HOST=ib-gateway
IBKR_PORT=4001
IBKR_CLIENT_ID=1

# Bridge HTTP server
PORT=8080
HOST=0.0.0.0

# Bearer token for incoming requests (set to a long random string)
BRIDGE_AUTH_TOKEN=replace-with-a-long-random-string

# Safety flag — must be "yes" to acknowledge that the IBKR account
# has the Read-Only API setting enabled in TWS/Gateway settings.
READ_ONLY_API=yes

# Logging
LOG_LEVEL=info
