# A&R Tastytrade Stack — secrets

# Tastytrade OAuth credentials (creados en my.tastytrade.com → Settings → API)
TT_CLIENT_ID=ede6...06bd
TT_CLIENT_SECRET=1a09...9bc1

# Token compartido entre worker y bridge (generar largo random)
# En worker: wrangler secret put TASTYTRADE_BRIDGE_TOKEN (mismo valor)
BRIDGE_TOKEN=cambiar_a_token_aleatorio_largo_64chars

# Redirect URI (debe coincidir con el registrado en la OAuth app)
TT_REDIRECT_URI=https://api.onto-so.com/api/tastytrade/oauth/callback

# Zona horaria
TZ=Europe/Madrid
