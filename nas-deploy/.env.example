# =============================================================================
# A&R IB Stack — environment variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# IBKR live account credentials
# -----------------------------------------------------------------------------
# Login user/password for your real (NOT paper) IBKR account.
# Make sure this same user has Read-Only API enabled in IBKR Account
# Settings → API → Settings → "Read-Only API" = checked.
TWS_USERID=
TWS_PASSWORD=

# Trading mode: must match the account type. Use `live` for the real account,
# `paper` for the paper-trading login. We deploy `live`.
TRADING_MODE=live

# CRITICAL safety switch. Tells IBC to enable Read-Only mode at the gateway
# level (separate from the account-level setting). Belt + suspenders.
# Leave as `yes` unless you very much know what you're doing.
READ_ONLY_API=yes

# -----------------------------------------------------------------------------
# Bridge auth (Bearer token — every request needs `Authorization: Bearer ...`)
# -----------------------------------------------------------------------------
# Generate with:  openssl rand -hex 32
# 64 hex chars = 256 bits of entropy. Strong enough.
BRIDGE_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Cloudflare Tunnel token
# -----------------------------------------------------------------------------
# From Cloudflare Zero Trust dashboard → Networks → Tunnels → your tunnel →
# Connector → Docker tab. Long base64 string starting with `eyJ...`.
# This token is what authorises the cloudflared daemon on this NAS to act as
# the named tunnel. Treat it like a password.
TUNNEL_TOKEN=

# -----------------------------------------------------------------------------
# Optional: timezone for all 3 containers (logs, IBC restart time)
# -----------------------------------------------------------------------------
TZ=Europe/Madrid
